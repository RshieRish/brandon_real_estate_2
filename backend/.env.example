# Database
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Security
JWT_SECRET=your-secret-key-here-minimum-32-characters
ADMIN_PASSWORD=change-me-immediately

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Google Calendar (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8000/api/v1/booking/calendar/callback
GOOGLE_CALENDAR_REFRESH_TOKEN=

# CORS
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000

# Auto-blog scheduler — set ENABLED=false to silence the in-process loop in dev.
BLOG_AUTO_POST_ENABLED=true
BLOG_AUTO_POST_INTERVAL_HOURS=24
